{
  "name": "fizzy-mcp",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "description": "MCP server for integrating AI agents with Fizzy",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "lint": "oxlint --fix",
    "lint:check": "oxlint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docs:dev": "pnpm --filter docs dev",
    "docs:build": "pnpm --filter docs build",
    "docs:deploy": "pnpm --filter docs deploy",
    "hosted:dev": "pnpm --filter @fizzy-mcp/hosted dev",
    "hosted:build": "pnpm --filter @fizzy-mcp/hosted build",
    "hosted:deploy": "pnpm --filter @fizzy-mcp/hosted deploy",
    "hosted:typecheck": "pnpm --filter @fizzy-mcp/hosted typecheck",
    "hosted:db:generate": "pnpm --filter @fizzy-mcp/hosted db:generate",
    "hosted:db:migrate": "pnpm --filter @fizzy-mcp/hosted db:migrate",
    "hosted:db:migrate:local": "pnpm --filter @fizzy-mcp/hosted db:migrate:local"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "oxlint": "^1.53.0",
    "prettier": "^3.4.0",
    "tsup": "^8.3.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
