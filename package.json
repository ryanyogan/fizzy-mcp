{
  "name": "fizzy-mcp",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "description": "MCP server for integrating AI agents with Fizzy",
  "scripts": {
    "build": "vp run -r build",
    "dev": "vp run -r --parallel dev",
    "test": "vp test",
    "test:watch": "vp test --watch",
    "check": "vp check",
    "lint": "vp lint --fix",
    "lint:check": "vp lint",
    "typecheck": "vp run -r typecheck",
    "clean": "vp run -r clean && rm -rf node_modules",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "docs:dev": "vp run -r --filter docs dev",
    "docs:build": "vp run -r --filter docs build",
    "docs:deploy": "vp run -r --filter docs deploy",
    "hosted:dev": "vp run -r --filter @fizzy-mcp/hosted dev",
    "hosted:build": "vp run -r --filter @fizzy-mcp/hosted build",
    "hosted:deploy": "vp run -r --filter @fizzy-mcp/hosted deploy",
    "hosted:typecheck": "vp run -r --filter @fizzy-mcp/hosted typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
