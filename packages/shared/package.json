{
  "name": "@fizzy-mcp/shared",
  "version": "0.1.0",
  "description": "Shared types, schemas, and utilities for Fizzy MCP",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./db": {
      "types": "./dist/db/schema.d.ts",
      "import": "./dist/db/schema.js",
      "require": "./dist/db/schema.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "test:watch": "vp test --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.0",
    "marked": "^17.0.4",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vite-plus": "catalog:"
  }
}
