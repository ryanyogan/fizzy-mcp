{
  "name": "@fizzy-do-mcp/hosted",
  "version": "0.2.0",
  "private": true,
  "description": "Hosted MCP server for Fizzy - open source, no auth required",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "test": "vp test",
    "test:watch": "vp test --watch",
    "typecheck": "wrangler types && tsc --noEmit",
    "clean": "rm -rf dist .wrangler"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.0",
    "hono": "^4.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@fizzy-do-mcp/client": "workspace:*",
    "@fizzy-do-mcp/shared": "workspace:*",
    "@fizzy-do-mcp/tools": "workspace:*",
    "@cloudflare/workers-types": "^4.20241205.0",
    "typescript": "^5.7.0",
    "vite-plus": "catalog:",
    "wrangler": "^3.99.0"
  }
}
