{
  "name": "@fizzy-mcp/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3001",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "pnpm build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply fizzy-mcp-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply fizzy-mcp-db --remote",
    "test": "vitest run"
  },
  "dependencies": {
    "@fizzy-mcp/shared": "workspace:*",
    "@cloudflare/vite-plugin": "^1.0.6",
    "@fontsource/geist-mono": "^5.2.5",
    "@fontsource/geist-sans": "^5.2.5",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.14",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-router": "^1.121.0",
    "@tanstack/react-start": "^1.121.0",
    "@tremor/react": "^3.18.7",
    "better-auth": "^1.2.9",
    "better-auth-cloudflare": "^0.2.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.44.2",
    "lucide-react": "^0.545.0",
    "nanoid": "^5.1.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.3.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250313.0",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "^0.5.5",
    "@tanstack/router-plugin": "^1.132.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "drizzle-kit": "^0.31.4",
    "jsdom": "^28.1.0",
    "typescript": "^5.7.2",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.5",
    "wrangler": "^4.14.0"
  }
