{
  "name": "fizzy-do-mcp",
  "version": "0.2.0",
  "description": "MCP server for integrating AI agents with Fizzy, Basecamp's task management tool",
  "author": "Ryan Yogan <ryan@yogan.dev>",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ryanyogan/fizzy-mcp.git",
    "directory": "apps/server"
  },
  "homepage": "https://fizzy.yogan.dev",
  "bugs": {
    "url": "https://github.com/ryanyogan/fizzy-mcp/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "fizzy-mcp": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "start": "node dist/index.js",
    "test": "vp test",
    "test:watch": "vp test --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.0",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "commander": "^12.1.0",
    "figlet": "^1.11.0",
    "gradient-string": "^3.0.0",
    "ora": "^9.3.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@fizzy-mcp/client": "workspace:*",
    "@fizzy-mcp/shared": "workspace:*",
    "@fizzy-mcp/tools": "workspace:*",
    "@types/figlet": "^1.7.0",
    "@types/gradient-string": "^1.1.6",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vite-plus": "catalog:"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "fizzy",
    "basecamp",
    "ai",
    "claude",
    "cursor",
    "llm",
    "task-management",
    "project-management"
  ]
}
